/target
# Cargo.lock IS committed for binary projects — ensures reproducible builds since gpui is
# tracked at HEAD via git+no-rev (matched to gpui-component's spec to avoid dep duplication).

# WASM build outputs
/www/node_modules/
/www/dist/
/www/bun.lock*
/www/src/wasm/*.js
/www/src/wasm/*.wasm

# Editor / OS
.DS_Store
.vscode/
.idea/
.claude/
*.swp
